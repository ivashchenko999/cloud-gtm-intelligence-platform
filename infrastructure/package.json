    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf cdk.out coverage"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.173.4",
    "constructs": "^10.4.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "aws-cdk": "^2.173.1",
    "tsx": "^4.19.2"
  }
}

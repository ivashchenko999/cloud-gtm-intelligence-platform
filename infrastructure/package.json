{
  "name": "@cloud-gtm/infrastructure",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "infrastructure": "bin/app.ts"
  },
  "scripts": {
    "build": "tsc --noEmit -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint bin lib",
